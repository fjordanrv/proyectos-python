    <action caption='Highlight Replacement Player' name='[Action4_D5DDF23332B94C739895FE81287E83F9]'>
      <activation auto-clear='true' type='on-hover' />
      <source dashboard='LamineY_Scouting_Replacement_Dashboard' type='sheet' worksheet='Top Replacements' />
      <command command='tsc:brush'>
        <param name='exclude' value='Target Profile,KPI Minutes,KPI Goals,KPI xG,KPI xG+xAG,Top Replacements,Percentile Profile' />
        <param name='field-captions' value='Player' />
        <param name='target' value='LamineY_Scouting_Replacement_Dashboard' />
      </command>
    </action>
    <datasources>
