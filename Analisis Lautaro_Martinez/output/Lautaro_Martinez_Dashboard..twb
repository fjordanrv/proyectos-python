      <column caption='True' datatype='boolean' name='[Calculation_0497566485868551]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='TRUE' />
      </column>
      <column caption='False' datatype='boolean' name='[Calculation_0497566485913608]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='FALSE' />
      </column>
      <column caption='Player Category' datatype='string' name='[Calculation_0668813611261953]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_target] THEN &quot;Target&quot;&#13;&#10;ELSEIF [replacement_rank] &lt;= 10 THEN &quot;Replacement&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
        <aliases>
