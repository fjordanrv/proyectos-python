      <column caption='Point Size' datatype='integer' name='[Calculation_0458807005429766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Player] = &quot;Lamine Yamal&quot; THEN 3&#13;&#10;ELSEIF [Calculation_0668813611261953] = &quot;Top 10 Replacements&quot; THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
